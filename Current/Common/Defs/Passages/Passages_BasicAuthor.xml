<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!-- Author's backstory -->
    <InspiredAuthorship.Passages.PassageDef>
        <defName>AuthorBackstory</defName>
        <workerClass>InspiredAuthorship.Passages.PassageWorker_AuthorBackstory</workerClass>
        <rules>
            <rulesStrings>
                <li>topic->[AUTHOR_possessive] past</li>
                <li>topic->[AUTHOR_possessive] backstory</li>
                <li>topic->[AUTHOR_possessive] personal history</li>
                <li>topic->[AUTHOR_possessive] past [story]s</li>

                <li>detail->[period]</li>
                <li>detail->a [story_dressed] from [period]</li>
                <li>detail->the [strife] of a [backstory_any]</li>
                <li>detail->the [strife] of [period]</li>
                <li>detail->[period], and the [strife]s that came with it</li>

                <li>period->[AUTHOR_possessive] childhood as a [AUTHOR_childhood]</li>
                <li>period->[AUTHOR_possessive] time as a [AUTHOR_adulthood]</li>
                <li>period->being a [backstory_any]</li>

                <li>backstory_any->[AUTHOR_childhood]</li>
                <li>backstory_any->[AUTHOR_adulthood]</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>


    <!-- Author's passions -->
    <InspiredAuthorship.Passages.PassageDef>
        <defName>AuthorPassions</defName>
        <workerClass>InspiredAuthorship.Passages.PassageWorker_SkillPassion</workerClass>
        <rules>
            <rulesStrings>
                <li>topic(p=4)->[AUTHOR_possessive] passion for [AUTHOR_skill]</li>
                <li>topic->a [discussion] about [AUTHOR_skill] work</li>
                <li>topic->[AUTHOR_skill] work</li>

                <li>detail->[subject]</li>
                <li>detail->[AUTHOR_possessive] interest in [subject]</li>
                <li>detail->[AUTHOR_possessive] knowledge in [subject]</li>

                <li>like->[AUTHOR_skill]</li>
                <li>like->[subject]</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>


    <!-- Author's skill mastery (level 14+) -->
    <InspiredAuthorship.Passages.PassageDef>
        <defName>AuthorMastery</defName>
        <workerClass>InspiredAuthorship.Passages.PassageWorker_SkillMastery</workerClass>
        <rules>
            <rulesStrings>
                <li>topic->[AUTHOR_possessive] mastery of [AUTHOR_skill]</li>
                <li>topic->mastering [AUTHOR_skill]</li>

                <li>detail->[subject]</li>
                <li>detail->[AUTHOR_possessive] peerless knowledge of [subject]</li>
                <li>detail->[AUTHOR_possessive] unrivaled aptitude for [subject]</li>

                <li>like->[AUTHOR_skill]</li>
                <li>like->[subject]</li>

                <li>trial->nights of ceaseless study</li>
                <li>trial->hard work and determination</li>
                <li>trial->devotion to [AUTHOR_possessive] craft</li>

                <li>reward->mastery of [AUTHOR_skill]</li>
                <li>reward->a deeper understanding of [AUTHOR_skill]</li>
                <li>reward->knowledge of [subject]</li>
                <li>reward->peerless [AUTHOR_skill] skill</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

</Defs>