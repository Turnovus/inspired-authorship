<?xml version="1.0" encoding="utf-8" ?>

<Defs>

    <!-- Common Data -->
    <RulePackDef>
        <defName>Turn_Authorship_TraitPassageGeneral</defName>
        <rulePack>
            <rulesStrings>
                <li>topic(p=0.1)->[AUTHOR_possessive] personality</li>
                <li>topic(p=0.1)->[AUTHOR_possessive] traits</li>
                <li>topic(p=0.1)->[AUTHOR_possessive] preferences</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

    <InspiredAuthorship.Passages.PassageDef Name="TraitPassageBase" Abstract="True">
        <rules>
            <include>
                <li>Turn_Authorship_TraitPassageGeneral</li>
            </include>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>


    <!-- Nudist -->
    <InspiredAuthorship.Passages.PassageDef ParentName="TraitPassageBase">
        <defName>TraitNudist</defName>

        <requiresAnyTrait>
            <li>Nudist</li>
        </requiresAnyTrait>

        <rules>
            <rulesStrings>
                <li>topic->nudism</li>
                <li>topic->[AUTHOR_possessive] nudity</li>
                <li>topic->being a nudist</li>

                <li>detail->the benefits of nudity</li>
                <li>detail->the drawbacks of clothing</li>
                <li>detail->confining garments</li>
                <li>detail->how [adjective_evil] clothing is</li>
                <li>detail->the liberty of bare skin</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Kind -->
    <InspiredAuthorship.Passages.PassageDef ParentName="TraitPassageBase">
        <defName>TraitKind</defName>

        <requiresAnyTrait>
            <li>Kind</li>
        </requiresAnyTrait>

        <rules>
            <rulesStrings>
                <li>topic->kindness</li>
                <li>topic->[AUTHOR_possessive] kind nature</li>
                <li>topic->being kind</li>

                <li>detail->proper decorum</li>
                <li>detail->respecting the feelings of others</li>
                <li>detail->the importance of politeness</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Cannibal -->
    <InspiredAuthorship.Passages.PassageDef ParentName="TraitPassageBase">
        <defName>TraitCannibal</defName>

        <requiresAnyTrait>
            <li>Cannibal</li>
        </requiresAnyTrait>

        <rules>
            <rulesStrings>
                <li>topic->cannibalism</li>
                <li>topic->[AUTHOR_possessive] taste for human flesh</li>
                <li>topic->being a cannibal</li>

                <li>detail->how human meat tastes</li>
                <li>detail->how to butcher a human</li>
                <li>detail->why human meat is superior</li>
                <li>detail->the flavor profiles of raiders from each of [LOCATION_planetName]'s faction</li>
                <li>detail->which of [AUTHOR_possessive] fellow [FACTION_pawnsPlural] look the tastiest</li>
                <li>detail->a ranking of [PAWN_possessive] fellow [FACTION_pawnsPlural] by how tasty they look</li>

                <li MayRequire="Ludeon.RimWorld.Biotech">detail->a ranking of each xenotype by flavor</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Abrasive -->
    <InspiredAuthorship.Passages.PassageDef ParentName="TraitPassageBase">
        <defName>TraitAbrasive</defName>

        <requiresAnyTrait>
            <li>Abrasive</li>
        </requiresAnyTrait>

        <rules>
            <rulesStrings>
                <li>topic->abrasiveness</li>
                <li>topic->[AUTHOR_possessive] crass demeanor</li>
                <li>topic->being abrasive</li>

                <li>detail->not caring what others think</li>
                <li>detail->a list of favorite obsceneties</li>
                <li>detail->the various annoying qualities of each other [FACTION_pawnSingular]</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Too Smart -->
    <InspiredAuthorship.Passages.PassageDef ParentName="TraitPassageBase">
        <defName>TraitTooSmart</defName>

        <requiresAnyTrait>
            <li>TooSmart</li>
        </requiresAnyTrait>

        <rules>
            <rulesStrings>
                <li>topic->being too smart for [AUTHOR_possessive] own good</li>

                <li>detail->overthinking things</li>
                <li>detail->needing to know everything</li>
                <li>detail->a categorical list of everything that could go wrong</li>
                <li>detail->the dangers of ignorance</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Brawler -->
    <InspiredAuthorship.Passages.PassageDef ParentName="TraitPassageBase">
        <defName>TraitBrawler</defName>

        <requiresAnyTrait>
            <li>Brawler</li>
        </requiresAnyTrait>

        <rules>
            <rulesStrings>
                <li>topic->brawling</li>
                <li>topic->[AUTHOR_possessive] [inclination] for [combat_melee]</li>
                <li>topic->being a brawler</li>

                <li>detail->pointers for [combat_melee]</li>
                <li>detail->stories of various fights [AUTHOR_pronoun] has been in</li>
                <li>detail->the joys of [combat_melee]</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Masochist -->
    <InspiredAuthorship.Passages.PassageDef ParentName="TraitPassageBase">
        <defName>TraitMasochist</defName>

        <requiresAnyTrait>
            <li>Masochist</li>
        </requiresAnyTrait>

        <rules>
            <rulesStrings>
                <li>topic->masochism</li>
                <li>topic->[AUTHOR_possessive] lust for pain</li>
                <li>topic->being a masochist</li>

                <li>detail->exciting injuries [AUTHOR_pronoun] has incurred</li>
                <li>detail->[AUTHOR_possessive] [inclination] for pain</li>
                <li>detail->the most exciting methods of torture</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>
    
</Defs>