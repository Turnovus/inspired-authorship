<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <InspiredAuthorship.Passages.PassageDef Name="GenericPassageBase" Abstract="True">
        <baseCommonality>0.01</baseCommonality>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Random story -->
    <InspiredAuthorship.Passages.PassageDef ParentName="GenericPassageBase">
        <defName>RandomStory</defName>
        <rules>
            <rulesStrings>
                <li>topic->a [tale_dressed]</li>

                <li>detail->the [strife]s of a [adjective_any] [person_any]</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Story with subject -->
    <InspiredAuthorship.Passages.PassageDef ParentName="GenericPassageBase">
        <defName>RandomStoryWithSubject</defName>
        <rules>
            <rulesStrings>
                <li>topic->a [tale_dressed] about [subject]</li>

                <li>detail->their [strife]s</li>
                <li>detail->their [story]s</li>

                <li>subject->a [person_any]</li>
                <li>subject->a [adjective_any] [person_any]</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

    <!-- Philosophy -->
    <InspiredAuthorship.Passages.PassageDef ParentName="GenericPassageBase">
        <defName>RandomPhilosophy</defName>
        <rules>
            <rulesStrings>
                <li>topic->a [discussion_dressed]</li>
                <li>topic->a [discussion_dressed] on [something]</li>

                <li>detail->[something] and [something]</li>
                <li>detail->counterpointing [something] with [something]</li>
                <li>detail->the concept of [something]</li>

                <li>something(p=6)->[concept_any]</li>
                <li>something->a [noun_concrete]</li>
                <li>something->[noun_concrete]</li>
                <li>something->a [adjective_any] [noun_concrete]</li>
                <li>something->[adjective_any] [noun_concrete]s</li>

                <li>like->[something]</li>
                <li>dislike->[something]</li>
            </rulesStrings>
        </rules>
    </InspiredAuthorship.Passages.PassageDef>

</Defs>