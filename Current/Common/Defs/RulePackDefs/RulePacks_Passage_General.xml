<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <RulePackDef>
        <defName>Turn_Authorship_BookDescriptionNew</defName>
        <rulePack>
            <rulesStrings>
                <li>desc->[start_book_description]. [middle_creation_details].\n\n[passages]</li>
                <li>desc->[start_creation_details]. [middle_book_description].\n\n[passages]</li>

                <li>start_book_description->A book [book_description]</li>
                <li>start_book_description->This book [book_description]</li>

                <li>middle_book_description->It [book_description]</li>

                <li>book_description->is crudely bound with [bindings]</li>

                <li>start_creation_details->This book was [creation_details]</li>

                <li>middle_creation_details->It was [creation details]</li>

                <li>creation_details->written on the planet [LOCATION_planetName] by [AUTHOR_nameFull] on the [creationDate]</li>

                <li>bindings->string</li>
                <li>bindings->tape</li>
                <li>bindings->staples</li>
                <li>bindings->leather straps</li>
                <li>bindings->nails</li>
                <li>bindings->glue</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

    <RulePackDef>
        <defName>Turn_Authorship_PassageUtility</defName>
        <rulePack>
            <include>
                <li>Turn_Authorship_RulePackUtility</li>
            </include>
            <rulesStrings>
                <li>topic_and_detail->[topic] and [detail]</li>
                <li>topic_and_detail->[topic], specifically [detail]</li>
                <li>topic_and_detail->[detail] as a part of [topic]</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

    <RulePackDef>
        <defName>Turn_Authorship_PassageStart</defName>
        <rulePack>
            <include>
                <li>Turn_Authorship_PassageUtility</li>
            </include>
            <rulesStrings>
                <li>passage->[AUTHOR_nameDef] opens with [topic], [discussing] [detail].</li>
                <li>passage->The book opens with [AUTHOR_nameDef] [discussing] [topic_and_detail].</li>
                <li>passage->The first [text] has [AUTHOR_nameDef] [discussing] [topic_and_detail].</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

    <RulePackDef>
        <defName>Turn_Authorship_PassageMiddle</defName>
        <rulePack>
            <include>
                <li>Turn_Authorship_PassageUtility</li>
            </include>
            <rulesStrings>
                <li>passage->[AUTHOR_nameDef] moves on to [topic], [discussing] [detail].</li>
                <li>passage->The book then continues with [AUTHOR_nameDef] [discussing] [topic_and_detail].</li>
                <li>passage->The next [text] has [AUTHOR_nameDef] [discussing] [topic_and_detail].</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

    <RulePackDef>
        <defName>Turn_Authorship_PassageEnd</defName>
        <rulePack>
            <include>
                <li>Turn_Authorship_PassageUtility</li>
            </include>
            <rulesStrings>
                <li>passage->[AUTHOR_nameDef] closes with [topic], [discussing] [detail].</li>
                <li>passage->The book closes with [AUTHOR_nameDef] [discussing] [topic_and_detail].</li>
                <li>passage->The final [text] has [AUTHOR_nameDef] [discussing] [topic_and_detail].</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>


</Defs>