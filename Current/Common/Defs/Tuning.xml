<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <InspiredAuthorship.ModTuningDef>
        <defName>ModTuning</defName>

        <!--Highest quality factor (% of max) for a book to be scrapped. Actual chance is linearly interpolated from 0 to this value. -->
        <maxQualityForScrapPossible>0.60</maxQualityForScrapPossible>
        <!-- How many days' worth of work is needed to receive a work quality offset of 1.0. -->
        <qualityTargetDays>10.00</qualityTargetDays>
        <!-- The maximum quality offset that can be gained from work. -->
        <maxWorkTimeContribution>0.60</maxWorkTimeContribution>
        <!-- The quality offset per each skill level, taken from the 3 highest skills. -->
        <offsetPerSkillLevel>0.015</offsetPerSkillLevel>
        <!-- The maximum quality offset that can be gained from skill. -->
        <maxSkillContribution>0.60</maxSkillContribution>
        <!-- A second cap is applied to skill contribution, equal to the product of this value and current work contribution. This prevents highly-skilled pawns from producing high-quality books without actually doing any work. A higher value makes the second cap easier to raise. -->
        <skillCapFromWorkFactor>2.5</skillCapFromWorkFactor>
        <!-- The upper limit of the random quality offset. -->
        <maxLuckContribution>0.50</maxLuckContribution>

        <!-- The random selection weight of each quality. The x value represents the quality factor from work, skill, and luck (% of maximum), and the y value represents the weight of that quality category for that quality factor. -->
        <qualitySelectionCurves>
            <li>
                <key>Awful</key>
                <value>
                    <points>
                        <li>(0.00, 10)</li>
                        <li>(0.10, 1.00)</li>
                        <li>(1.00, 0.001)</li>
                    </points>
                </value>
            </li>
            <li>
                <key>Poor</key>
                <value>
                    <points>
                        <li>(0.00, 2.00)</li>
                        <li>(1.00, 0.02)</li>
                    </points>
                </value>
            </li>
            <li>
                <key>Normal</key>
                <value>
                    <points>
                        <li>(0.00, 0.25)</li>
                        <li>(0.50, 1.00)</li>
                        <li>(1.00, 0.25)</li>
                    </points>
                </value>
            </li>
            <li>
                <key>Good</key>
                <value>
                    <points>
                        <li>(0.00, 0.00)</li>
                        <li>(0.10, 0.05)</li>
                        <li>(1.00, 2.00)</li>
                    </points>
                </value>
            </li>
            <li>
                <key>Excellent</key>
                <value>
                    <points>
                        <li>(0.00, 0.00)</li>
                        <li>(0.20, 0.00)</li>
                        <li>(1.00, 1.50)</li>
                    </points>
                </value>
            </li>
            <li>
                <key>Masterwork</key>
                <value>
                    <points>
                        <li>(0.00, 0.00)</li>
                        <li>(0.50, 0.00)</li>
                        <li>(1.00, 0.75)</li>
                    </points>
                </value>
            </li>
            <li>
                <key>Legendary</key>
                <value>
                    <points>
                        <li>(0.00, 0.00)</li>
                        <li>(0.70, 0.00)</li>
                        <li>(1.00, 0.35)</li>
                    </points>
                </value>
            </li>
        </qualitySelectionCurves>

        <bookDefs>
            <li>Turn_Authorship_Memoir</li>
        </bookDefs>

        <writtenBookNamer>Turn_Authorship_WrittenBookNamer</writtenBookNamer>
        <writtenBookDescriberNew>Turn_Authorship_BookDescriptionNew</writtenBookDescriberNew>

        <passageStartRules>Turn_Authorship_PassageStart</passageStartRules>
        <passageMiddleRules>Turn_Authorship_PassageMiddle</passageMiddleRules>
        <passageEndRules>Turn_Authorship_PassageEnd</passageEndRules>

        <maxPassageCount>6</maxPassageCount>
        <idealMinPassageCount>2</idealMinPassageCount>

        <writtenBooksRecord>Turn_Record_BooksWritten</writtenBooksRecord>
    </InspiredAuthorship.ModTuningDef>

</Defs>