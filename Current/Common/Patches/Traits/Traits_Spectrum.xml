            <li Class="InspiredAuthorship.Passages.ModExtension_TraitRules">
                <rulesByDegree>
                    <li>
                        <degree>-2</degree>
                        <rules>
                            <include>
                                <li>Turn_Authorship_PessimistTraitRules</li>
                            </include>
                        </rules>
                    </li>

                    <li>
                        <degree>-1</degree>
                        <rules>
                            <include>
                                <li>Turn_Authorship_PessimistTraitRules</li>
                            </include>
                        </rules>
                    </li>

                    <li>
                        <degree>1</degree>
                        <rules>
                            <include>
                                <li>Turn_Authorship_OptimistTraitRules</li>
                            </include>
                        </rules>
                    </li>

                    <li>
                        <degree>2</degree>
                        <rules>
                            <include>
                                <li>Turn_Authorship_OptimistTraitRules</li>
                            </include>
                        </rules>
                    </li>
                </rulesByDegree>
            </li>
        </value>
    </Operation>

