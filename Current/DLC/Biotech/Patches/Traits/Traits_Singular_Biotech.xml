<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/TraitDef[defName="Recluse"]</xpath>
        <value>
            <li Class="InspiredAuthorship.Passages.ModExtension_TraitRules">
                <rulesByDegree>
                    <li>
                        <rules>
                            <rulesStrings>
                                <li>topic->solitude</li>
                                <li>topic->being left alone</li>
                                <li>topic->reclusiveness</li>

                                <li>detail->why [AUTHOR_pronoun] prefers to be left alone</li>
                                <li>detail->why being alone doesn't really bother [AUTHOR_objective]</li>
                                <li>detail->not being able to connect with others</li>

                                <li>like->solitude</li>
                                <li>like->quiet</li>
                                <li>like->being alone</li>

                                <li>dislike->friends</li>
                                <li>dislike->company</li>
                                <li>dislike->socializing</li>
                                <li>dislike->having a social life</li>
                            </rulesStrings>
                        </rules>
                    </li>
                </rulesByDegree>
            </li>
        </value>
    </Operation>
    

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/TraitDef[defName="Delicate"]</xpath>
        <value>
            <li Class="InspiredAuthorship.Passages.ModExtension_TraitRules">
                <rulesByDegree>
                    <li>
                        <rules>
                            <include>
                                <li>Turn_Authorship_WimpyTraitRules</li>
                            </include>
                        </rules>
                    </li>
                </rulesByDegree>
            </li>
        </value>
    </Operation>

</Patch>